---
import "../styles/global.css";
import type { Language } from "../utils/i18n";
import { getAlternateUrl } from "../utils/i18n";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  lang?: Language;
  description?: string;
  image?: string;
}

const {
  title,
  lang = "en",
  description = "Paulina Velazquez - Architect Portfolio",
  image,
} = Astro.props;

const canonicalUrl = Astro.url.href;
const siteUrl = Astro.site?.origin ?? "https://paulinavlzqz.vercel.app";
const ogImage = image ? new URL(image, siteUrl).href : `${siteUrl}/og-image.png`;

const currentPath = Astro.url.pathname;
const alternatePath = getAlternateUrl(currentPath, lang);
const enUrl = lang === "en" ? canonicalUrl : `${siteUrl}${alternatePath}`;
const esUrl = lang === "es" ? canonicalUrl : `${siteUrl}${alternatePath}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      name: "Paulina Velazquez",
      jobTitle: lang === "es" ? "Arquitecta" : "Architect",
      url: siteUrl,
      address: {
        "@type": "PostalAddress",
        addressLocality: lang === "es" ? "Ciudad de México" : "Mexico City",
        addressCountry: "MX",
      },
    },
    {
      "@type": "WebSite",
      url: siteUrl,
      name: "Paulina Velazquez Portfolio",
      inLanguage: [lang === "es" ? "es-MX" : "en-US"],
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f5f4f0" />
    <title>{title}</title>

    <!-- Canonical & Hreflang -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === "es" ? "es_MX" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "es" ? "en_US" : "es_MX"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <ClientRouter />

    <style is:global>
      :root {
        --canvas: #f5f4f0;
        --grid-line: #e0ddd5;
        --spacer-bg: #efeee9;
        --terracotta: #f9e4d4;
        --sage: #e2f0e9;
        --cement: #e8e7f2;
      }

      body {
        background-color: var(--canvas);
        color: #1a1a1a;
      }

      .grid-line-h {
        border-bottom: 1px solid var(--grid-line);
      }
      .grid-line-v {
        border-right: 1px solid var(--grid-line);
      }

      .spacing-block {
        background-color: var(--spacer-bg);
        background-image: radial-gradient(
          var(--grid-line) 0.5px,
          transparent 0.5px
        );
        background-size: 10px 10px;
      }

      .hatch-pattern {
        background-image: repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 4px,
          var(--grid-line) 7px,
          var(--grid-line) 7px
        );
        opacity: 0.5;
      }

      .hatch-pattern-fine {
        background-image: repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 3px,
          var(--grid-line) 3px,
          var(--grid-line) 4px
        );
        opacity: 0.3;
      }

      @media (max-width: 767px) {
        .bento-card {
          grid-column: 1 / -1 !important;
          grid-row: span 1 !important;
        }
      }

      .material-symbols-outlined {
        font-variation-settings:
          "FILL" 0,
          "wght" 200,
          "GRAD" 0,
          "opsz" 24;
        vertical-align: middle;
      }
    </style>
  </head>
  <body class="font-sans overflow-x-hidden">
    <slot />
  </body>
</html>
