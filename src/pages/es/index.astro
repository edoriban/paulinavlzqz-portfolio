---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import BentoGrid from "../../components/BentoGrid.astro";
import BentoCard from "../../components/BentoCard.astro";
import CtaContact from "../../components/CtaContact.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations } from "../../utils/i18n";

import sagrarioHero from "../../assets/images/sagrario-hero.png";
import sagrario from "../../assets/images/sagrario.png";
import sagrario3 from "../../assets/images/sagrario3.png";
import sagrarioUpView from "../../assets/images/sagrario-up-view.png";

const lang = "es";
const t = useTranslations(lang);
---

<Layout title="Paulina Velazquez | Arquitecta" lang={lang} description={t("meta.description")}>
  <Nav lang={lang} />

  <main class="w-full">
    <Hero lang={lang} />

    <section id="work" class="w-full border-t border-gridLine">
      <!-- Section Header aligned to grid -->
      <div class="w-full grid-line-h h-14 flex bg-[#EFEEE9]">
        <div class="hidden md:block w-1/12 grid-line-v spacing-block"></div>
        <div class="flex-1 md:w-7/12 md:flex-none grid-line-v px-6 md:px-20 flex items-center">
          <h2
            class="font-display text-[11px] font-bold tracking-[0.4em] uppercase opacity-60 text-primary"
          >
            {t("works.title")}
          </h2>
        </div>
        <div class="hidden md:block w-3/12 grid-line-v spacing-block"></div>
        <div class="hidden md:block w-1/12 spacing-block"></div>
      </div>

      <BentoGrid class="w-full">
        <!-- [00] SIDEBAR LEFT -->
        <div
          class="hidden md:flex col-span-1 row-span-4 grid-line-v spacing-block items-center justify-center relative min-h-[1000px]"
        >
          <span
            class="text-[10px] font-mono rotate-90 whitespace-nowrap opacity-40 uppercase block"
            >Proyectos.Archivo.24</span
          >
        </div>

        <!-- [01] MAIN PROJECT -->
        <BentoCard
          colSpan="span 7"
          rowSpan="span 2"
          variant="canvas"
          class="p-0"
        >
          <div
            class="group relative w-full h-full min-h-[600px] overflow-hidden"
          >
            <Image
              src={sagrarioHero}
              alt="Fotografía arquitectónica de la cúpula del Sagrario Metropolitano"
              class="w-full h-[680px] object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105 opacity-90 grayscale mix-blend-multiply"
              widths={[480, 800, 1200]}
              sizes="(max-width: 768px) 100vw, 58vw"
            />
            <div
              class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-60 transition-opacity duration-700 pointer-events-none hatch-pattern brightness-50"
            >
            </div>

            <div
              class="absolute top-8 right-8 text-[9px] font-mono opacity-100 uppercase tracking-widest border border-primary/20 px-3 py-1.5 bg-[#FCFAF7]/80 backdrop-blur-md z-20 text-primary"
            >
              {t("works.pantheon.type")}
            </div>

            <div class="absolute bottom-12 left-12 right-12 z-30">
              <div
                class="inline-block bg-[#1A1A1A]/90 backdrop-blur-xl p-10 border border-white/10 shadow-2xl"
              >
                <div class="h-12 w-px bg-canvas/30 mb-6"></div>
                <h3
                  class="font-display text-4xl md:text-6xl font-bold tracking-tight mb-4 text-canvas"
                >
                  Sagrario Metropolitano
                </h3>
                <p
                  class="text-xs font-mono opacity-80 uppercase tracking-[0.2em] text-canvas"
                >
                  {t("works.pantheon.location")}
                </p>
              </div>
            </div>
          </div>
        </BentoCard>

        <!-- [02] QUOTE CARD -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="surface"
          class="p-10 flex flex-col justify-center group relative overflow-hidden quote-card"
        >
          <!-- Subtle Gradient Background -->
          <div
            class="absolute inset-0 bg-gradient-to-br from-primary/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"
          >
          </div>

          <div class="relative z-10">
            <!-- Decorative Quote Icon -->
            <div class="mb-6 opacity-20">
              <svg
                width="32"
                height="24"
                viewBox="0 0 32 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="text-primary group-hover:translate-x-1 transition-transform duration-500"
              >
                <path
                  d="M9.14286 0L12 5.33333V24H0V10.6667H6.85714L4 0H9.14286ZM29.1429 0L32 5.33333V24H20V10.6667H26.8571L24 0H29.1429Z"
                  fill="currentColor"></path>
              </svg>
            </div>

            <p
              class="text-2xl md:text-3xl font-display italic font-light leading-tight tracking-tight text-primary/80 group-hover:text-primary transition-colors duration-500 mb-8"
            >
              "La arquitectura es el juego sabio, correcto y magnífico de los
              volúmenes bajo la luz."
            </p>

            <div class="flex items-center gap-4">
              <div
                class="h-px w-8 bg-primary/20 group-hover:w-12 transition-all duration-500"
              >
              </div>
              <span
                class="text-[10px] font-mono opacity-40 uppercase tracking-[0.3em] group-hover:opacity-80 transition-opacity"
              >
                Le Corbusier
              </span>
            </div>
          </div>

          <!-- Floating Grid Detail -->
          <div
            class="absolute -bottom-10 -right-10 w-40 h-40 opacity-[0.05] group-hover:opacity-[0.1] transition-opacity duration-700 pointer-events-none rotate-12"
          >
            <div
              class="w-full h-full"
              style="background-image: radial-gradient(currentColor 1px, transparent 1px); background-size: 16px 16px;"
            >
            </div>
          </div>
        </BentoCard>

        <!-- [03] SIDEBAR RIGHT -->
        <div class="hidden md:block col-span-1 row-span-4 spacing-block"></div>

        <!-- [04] DOME VISUAL -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="primary"
          class="p-0 flex flex-col justify-center items-center overflow-hidden group min-h-[350px] bg-[#1A1A1A]"
        >
          <!-- CSS-only animated wireframe sphere -->
          <div class="absolute inset-0 z-[1] flex items-center justify-center">
            <div class="dome-wireframe w-48 h-48 relative">
              <svg
                viewBox="0 0 200 200"
                class="w-full h-full animate-spin-slow"
              >
                <defs>
                  <linearGradient
                    id="domeGradientEs"
                    x1="0%"
                    y1="0%"
                    x2="100%"
                    y2="100%"
                  >
                    <stop offset="0%" stop-color="#F9E4D4" stop-opacity="0.9"
                    ></stop>
                    <stop offset="100%" stop-color="#E2F0E9" stop-opacity="0.6"
                    ></stop>
                  </linearGradient>
                </defs>
                <!-- Horizontal rings -->
                <ellipse
                  cx="100"
                  cy="100"
                  rx="80"
                  ry="80"
                  fill="none"
                  stroke="url(#domeGradientEs)"
                  stroke-width="0.5"
                  opacity="0.8"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="80"
                  ry="30"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.6"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="80"
                  ry="60"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.5"></ellipse>
                <ellipse
                  cx="100"
                  cy="85"
                  rx="65"
                  ry="25"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.4"></ellipse>
                <ellipse
                  cx="100"
                  cy="115"
                  rx="65"
                  ry="25"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.4"></ellipse>
                <!-- Vertical meridians -->
                <ellipse
                  cx="100"
                  cy="100"
                  rx="30"
                  ry="80"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.5"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="60"
                  ry="80"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.4"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="10"
                  ry="80"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.3"></ellipse>
                <!-- Diagonal lines for geodesic effect -->
                <line
                  x1="20"
                  y1="100"
                  x2="180"
                  y2="100"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.3"></line>
                <line
                  x1="100"
                  y1="20"
                  x2="100"
                  y2="180"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.3"></line>
                <line
                  x1="35"
                  y1="35"
                  x2="165"
                  y2="165"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.2"></line>
                <line
                  x1="165"
                  y1="35"
                  x2="35"
                  y2="165"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.2"></line>
              </svg>
            </div>
          </div>

          <!-- Glassmorphism Overlay Label -->
          <div
            class="absolute bottom-6 left-6 right-6 z-20 p-5 bg-[#F5F4F0]/5 backdrop-blur-md border border-[#F5F4F0]/10 flex justify-between items-end transform translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-700"
          >
            <div>
              <span
                class="text-[8px] font-mono text-[#F5F4F0]/40 uppercase tracking-[0.2em] mb-1 block"
                >Componente</span
              >
              <h4
                class="text-xs font-display font-bold text-[#F5F4F0] uppercase tracking-widest"
              >
                Síntesis Estructural
              </h4>
            </div>
            <div class="text-right">
              <span
                class="text-[8px] font-mono text-[#F5F4F0]/40 uppercase block"
                >Ref. 402-A</span
              >
            </div>
          </div>

          <!-- Top Technical Details -->
          <div
            class="absolute top-6 left-6 right-6 z-20 flex justify-between opacity-30"
          >
            <div class="w-2 h-2 border border-[#F9E4D4]/40"></div>
            <div
              class="text-[7px] font-mono text-[#F9E4D4]/60 uppercase tracking-[0.4em]"
            >
              Simulación Activa
            </div>
            <div class="w-2 h-2 border border-[#F9E4D4]/40"></div>
          </div>
        </BentoCard>

        <!-- [05] PHILOSOPHY -->
        <BentoCard
          id="philosophy"
          colSpan="span 5"
          rowSpan="span 1"
          variant="primary"
          class="p-12 md:p-16 flex flex-col justify-center relative overflow-hidden group"
        >
          <div
            class="absolute top-0 left-0 w-full h-full opacity-20 group-hover:opacity-30 transition-opacity duration-700 pointer-events-none hatch-pattern-fine"
          >
          </div>
          <div class="relative z-10">
            <span
              class="text-[9px] font-mono opacity-50 uppercase tracking-[0.3em] mb-8 block text-terracotta/80 philosophy-label"
              >Filosofía</span
            >
            <p
              class="text-2xl md:text-4xl font-display italic font-light leading-tight mb-8 max-w-2xl text-canvas/90 philosophy-quote"
            >
              "La arquitectura debe hablar de su tiempo y su lugar."
            </p>
            <div class="flex items-center gap-4">
              <div class="h-px w-8 bg-terracotta/40 philosophy-line"></div>
              <p
                class="text-[10px] font-mono opacity-60 uppercase tracking-[0.2em] text-terracotta philosophy-author"
              >
                Frank Gehry
              </p>
            </div>
          </div>
        </BentoCard>

        <!-- [06] DETAIL IMAGE -->
        <BentoCard
          colSpan="span 2"
          rowSpan="span 1"
          variant="image"
          class="p-0"
        >
          <div class="relative w-full h-full min-h-[300px]">
            <Image
              src={sagrarioUpView}
              alt="Vista interior de la cúpula del Sagrario Metropolitano desde abajo"
              class="w-full h-full object-cover grayscale brightness-105"
              widths={[320, 640]}
              sizes="(max-width: 768px) 100vw, 17vw"
              loading="lazy"
            />
            <div
              class="absolute bottom-6 left-6 bg-primary text-canvas text-[9px] px-3 py-1.5 font-mono uppercase tracking-widest"
            >
              Detalle 406
            </div>
          </div>
        </BentoCard>

        <!-- [07] NUESTRO PROCESO -->
        <BentoCard
          id="process"
          colSpan="span 3"
          rowSpan="span 1"
          variant="surface"
          class="p-0 group overflow-hidden"
        >
          <div class="flex flex-col h-full">
            <!-- Header -->
            <div class="p-8 pb-6 border-b border-gridLine bg-[#EFEEE9]">
              <span
                class="text-[9px] font-mono opacity-40 uppercase tracking-[0.2em] block process-title"
                >Nuestro Proceso</span
              >
            </div>

            <!-- Steps Container -->
            <div class="flex flex-col flex-1 bg-[#FCFAF7]">
              <!-- Step 1 -->
              <div
                class="group/step flex-1 flex items-stretch border-b border-gridLine hover:bg-white transition-colors duration-300 cursor-default relative process-step"
              >
                <div
                  class="w-16 border-r border-gridLine flex items-center justify-center bg-[#EFEEE9]/30 group-hover/step:bg-primary group-hover/step:text-white transition-colors duration-300"
                >
                  <span class="text-[10px] font-mono tracking-widest">01</span>
                </div>
                <div class="flex-1 p-5 flex flex-col justify-center relative">
                  <h4
                    class="text-[11px] font-display font-bold uppercase tracking-[0.2em] text-primary mb-1"
                  >
                    Conceptualizar
                  </h4>
                  <p
                    class="text-[9px] font-mono opacity-50 tracking-wide max-w-[150px]"
                  >
                    Investigación e Ideación
                  </p>
                  <!-- Hover Arrow -->
                  <div
                    class="absolute right-5 top-1/2 -translate-y-1/2 opacity-0 group-hover/step:opacity-100 -translate-x-2 group-hover/step:translate-x-0 transition-all duration-300"
                  >
                                      <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-4 h-4 text-primary"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                  </div>
                </div>
              </div>

              <!-- Step 2 -->
              <div
                class="group/step flex-1 flex items-stretch border-b border-gridLine hover:bg-white transition-colors duration-300 cursor-default relative process-step"
              >
                <div
                  class="w-16 border-r border-gridLine flex items-center justify-center bg-[#EFEEE9]/30 group-hover/step:bg-primary group-hover/step:text-white transition-colors duration-300"
                >
                  <span class="text-[10px] font-mono tracking-widest">02</span>
                </div>
                <div class="flex-1 p-5 flex flex-col justify-center">
                  <h4
                    class="text-[11px] font-display font-bold uppercase tracking-[0.2em] text-primary mb-1"
                  >
                    Modelar
                  </h4>
                  <p
                    class="text-[9px] font-mono opacity-50 tracking-wide max-w-[150px]"
                  >
                    Digital y Físico
                  </p>
                  <div
                    class="absolute right-5 top-1/2 -translate-y-1/2 opacity-0 group-hover/step:opacity-100 -translate-x-2 group-hover/step:translate-x-0 transition-all duration-300"
                  >
                                      <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-4 h-4 text-primary"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                  </div>
                </div>
              </div>

              <!-- Step 3 -->
              <div
                class="group/step flex-1 flex items-stretch hover:bg-white transition-colors duration-300 cursor-default relative process-step"
              >
                <div
                  class="w-16 border-r border-gridLine flex items-center justify-center bg-[#EFEEE9]/30 group-hover/step:bg-primary group-hover/step:text-white transition-colors duration-300"
                >
                  <span class="text-[10px] font-mono tracking-widest">03</span>
                </div>
                <div class="flex-1 p-5 flex flex-col justify-center">
                  <h4
                    class="text-[11px] font-display font-bold uppercase tracking-[0.2em] text-primary mb-1"
                  >
                    Ejecutar
                  </h4>
                  <p
                    class="text-[9px] font-mono opacity-50 tracking-wide max-w-[150px]"
                  >
                    Construcción y Detalle
                  </p>
                  <div
                    class="absolute right-5 top-1/2 -translate-y-1/2 opacity-0 group-hover/step:opacity-100 -translate-x-2 group-hover/step:translate-x-0 transition-all duration-300"
                  >
                                      <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="w-4 h-4 text-primary"
                  >
                    <path d="M5 12h14"></path>
                    <path d="m12 5 7 7-7 7"></path>
                  </svg>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </BentoCard>

        <!-- [08] ARCHIVO MONOLITO -->
        <BentoCard
          colSpan="span 7"
          rowSpan="span 1"
          variant="surface"
          class="p-0 group"
        >
          <div class="relative w-full h-full flex flex-col min-h-[300px]">
            <div class="flex-grow overflow-hidden bg-[#fafafa] flex">
              <div class="hidden md:block w-1/2 h-[680px] overflow-hidden border-r border-gridLine">
                <Image
                  src={sagrario}
                  alt="Dibujo arquitectónico de análisis de perspectiva del Sagrario Metropolitano"
                  class="w-full h-full object-contain grayscale opacity-90 mix-blend-multiply"
                  widths={[400, 800]}
                  sizes="(max-width: 768px) 100vw, 29vw"
                  loading="lazy"
                />
              </div>
              <div class="w-full md:w-1/2 h-[400px] md:h-[680px] overflow-hidden">
                <Image
                  src={sagrario3}
                  alt="Dibujo estructural de sección transversal de la cúpula del Sagrario Metropolitano"
                  class="w-full h-full object-contain grayscale opacity-90 mix-blend-multiply"
                  widths={[400, 800]}
                  sizes="(max-width: 768px) 100vw, 29vw"
                  loading="lazy"
                />
              </div>
            </div>
            <div
              class="p-8 border-t border-gridLine flex justify-between items-end bg-white"
            >
              <div>
                <h4
                  class="text-xs font-display font-bold uppercase tracking-[0.1em]"
                >
                  {t("vertex.title")}
                </h4>
                <p class="text-[9px] font-mono opacity-40 mt-1">
                  {t("vertex.location")}
                </p>
              </div>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="w-3 h-3 opacity-20 group-hover:rotate-90 transition-transform duration-500"
              >
                <path d="M5 12h14"></path>
                <path d="M12 5v14"></path>
              </svg>
            </div>
          </div>
        </BentoCard>

        <!-- [09] AVAILABILITY CARD -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="primary"
          class="p-0 group"
        >
          <div class="flex flex-col h-full">
            <!-- Header: Status -->
            <div class="px-8 pt-8 pb-5 border-b border-white/[0.07]">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-2 h-2 bg-[#E2F0E9] rounded-full animate-pulse"></div>
                <span class="text-[8px] font-mono text-canvas/40 uppercase tracking-[0.3em]">{t("grid.status.label")}</span>
              </div>
              <h4 class="font-display text-base font-bold text-canvas/90 uppercase tracking-[0.15em] leading-tight">
                {t("grid.status.value")}
              </h4>
            </div>

            <!-- Info rows -->
            <div class="flex-1 flex flex-col text-[9px] font-mono uppercase tracking-widest">
              <div class="flex-1 flex items-center px-8 border-b border-white/[0.07]">
                <span class="text-canvas/25 w-12 shrink-0">{t("grid.scope")}</span>
                <span class="text-canvas/60">{t("grid.scope.value")}</span>
              </div>
              <div class="flex-1 flex items-center px-8 border-b border-white/[0.07]">
                <span class="text-canvas/25 w-12 shrink-0">{t("grid.reply")}</span>
                <span class="text-canvas/60">{t("grid.reply.value")}</span>
              </div>
              <div class="flex-1 flex items-center px-8 border-b border-white/[0.07]">
                <span class="text-canvas/25 w-12 shrink-0">{t("grid.slots")}</span>
                <span class="text-terracotta/70">{t("grid.slots.value")}</span>
              </div>
              <div class="flex-1 flex items-center px-8 border-b border-white/[0.07]">
                <span class="text-canvas/25 w-12 shrink-0">{t("grid.exp")}</span>
                <span class="text-canvas/60">{t("grid.exp.value")}</span>
              </div>
            </div>

            <!-- Footer: CTA -->
            <a href="#contact" class="px-8 py-5 flex items-center justify-between hover:bg-white/[0.03] transition-colors duration-500">
              <span class="text-[10px] font-display font-bold text-canvas/50 uppercase tracking-[0.2em] group-hover:text-canvas/80 transition-colors duration-500">
                {t("grid.cta")}
              </span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4 text-canvas/20 group-hover:text-terracotta/60 group-hover:-translate-y-1 group-hover:translate-x-1 transition-all duration-500">
                <path d="M7 17L17 7" stroke-linecap="round" stroke-linejoin="round"></path>
                <path d="M7 7h10v10" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
        </BentoCard>

      </BentoGrid>
    </section>

    <!-- Horizontal Separation Spacer with vertical grid lines -->
    <div class="w-full grid-line-h h-12 flex border-t border-gridLine">
      <div class="w-1/12 grid-line-v spacing-block"></div>
      <div class="w-7/12 grid-line-v spacing-block"></div>
      <div class="w-3/12 grid-line-v spacing-block"></div>
      <div class="w-1/12 spacing-block"></div>
    </div>

    <CtaContact lang={lang} />

    <Footer lang={lang} />
  </main>
</Layout>

<script>
  import { initAnimations } from "../../utils/animations";
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    initAnimations();

    // Philosophy Component Animation
    const philosophySection = document.getElementById("philosophy");
    if (philosophySection) {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: philosophySection,
          start: "top 80%",
          toggleActions: "play none none reverse",
        },
      });

      tl.fromTo(
        "#philosophy .hatch-pattern-fine",
        { opacity: 0, scale: 1.1 },
        { opacity: 0.2, scale: 1, duration: 1.5, ease: "power2.out" }
      )
        .fromTo(
          ".philosophy-label",
          { y: 15, opacity: 0 },
          { y: 0, opacity: 0.5, duration: 1, ease: "power3.out" },
          "-=1.2"
        )
        .fromTo(
          ".philosophy-quote",
          { y: 20, opacity: 0, filter: "blur(5px)" },
          {
            y: 0,
            opacity: 1,
            filter: "blur(0px)",
            duration: 1.2,
            ease: "power2.out",
          },
          "-=0.8"
        )
        .fromTo(
          ".philosophy-line",
          { width: 0, opacity: 0 },
          { width: "2rem", opacity: 1, duration: 0.8, ease: "power2.inOut" },
          "-=0.8"
        )
        .fromTo(
          ".philosophy-author",
          { x: -10, opacity: 0 },
          { x: 0, opacity: 0.6, duration: 0.8, ease: "power2.out" },
          "-=0.6"
        );
    }

    // Process Component Animation
    const processSection = document.getElementById("process");
    if (processSection) {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: processSection,
          start: "top 85%",
          toggleActions: "play none none reverse",
        },
      });

      tl.fromTo(
        ".process-title",
        { opacity: 0, x: -10 },
        { opacity: 0.4, x: 0, duration: 1, ease: "power2.out" }
      ).fromTo(
        ".process-step",
        { opacity: 0, x: -20 },
        { opacity: 1, x: 0, duration: 0.8, stagger: 0.2, ease: "power2.out" },
        "-=0.6"
      );
    }
  });
</script>
