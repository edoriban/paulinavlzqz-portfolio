---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import BentoGrid from "../../components/BentoGrid.astro";
import BentoCard from "../../components/BentoCard.astro";
import Footer from "../../components/Footer.astro";
import { useTranslations } from "../../utils/i18n";
import { Layers, TrendingUp, ArrowRight, Mail, Plus } from "lucide-astro";

const lang = "es";
const t = useTranslations(lang);
---

<Layout title="Paulina Velazquez | Arquitecta" lang={lang}>
  <Nav lang={lang} />

  <main class="w-full">
    <Hero lang={lang} />

    <section id="work" class="w-full border-t border-gridLine">
      <!-- Section Header aligned to grid -->
      <div class="w-full grid-line-h h-14 flex bg-[#EFEEE9]">
        <div class="w-1/12 grid-line-v spacing-block"></div>
        <div class="w-7/12 grid-line-v px-12 md:px-20 flex items-center">
          <h2
            class="font-display text-[11px] font-bold tracking-[0.4em] uppercase opacity-60 text-primary"
          >
            {t("works.title")}
          </h2>
        </div>
        <div class="w-3/12 grid-line-v spacing-block"></div>
        <div class="w-1/12 spacing-block"></div>
      </div>

      <BentoGrid class="w-full">
        <!-- [00] SIDEBAR LEFT -->
        <div
          class="col-span-1 row-span-4 grid-line-v spacing-block flex items-center justify-center relative min-h-[1000px]"
        >
          <span
            class="text-[10px] font-mono rotate-90 whitespace-nowrap opacity-40 uppercase block"
            >Proyectos.Archivo.24</span
          >
        </div>

        <!-- [01] MAIN PROJECT -->
        <BentoCard
          colSpan="span 7"
          rowSpan="span 2"
          variant="canvas"
          class="p-0"
        >
          <div
            class="group relative w-full h-full min-h-[600px] overflow-hidden"
          >
            <img
              alt="Renacimiento del Panteón"
              class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105 opacity-90 grayscale mix-blend-multiply"
              src="/images/projects/pantheon.png"
            />
            <div
              class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-60 transition-opacity duration-700 pointer-events-none hatch-pattern brightness-50"
            >
            </div>

            <div
              class="absolute top-8 right-8 text-[9px] font-mono opacity-100 uppercase tracking-widest border border-primary/20 px-3 py-1.5 bg-[#FCFAF7]/80 backdrop-blur-md z-20 text-primary"
            >
              TIPO A1 : r/e: 43
            </div>

            <div class="absolute bottom-12 left-12 right-12 z-30">
              <div
                class="inline-block bg-[#1A1A1A]/90 backdrop-blur-xl p-10 border border-white/10 shadow-2xl"
              >
                <div class="h-12 w-px bg-canvas/30 mb-6"></div>
                <h3
                  class="font-display text-4xl md:text-6xl font-bold tracking-tight mb-4 text-canvas"
                >
                  Renacimiento del Panteón
                </h3>
                <p
                  class="text-xs font-mono opacity-80 uppercase tracking-[0.2em] text-canvas"
                >
                  Roma, Italia — 2023
                </p>
              </div>
            </div>
          </div>
        </BentoCard>

        <!-- [02] QUOTE CARD -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="surface"
          class="p-10 flex flex-col justify-center group relative overflow-hidden quote-card"
        >
          <!-- Subtle Gradient Background -->
          <div
            class="absolute inset-0 bg-gradient-to-br from-primary/[0.02] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"
          >
          </div>

          <div class="relative z-10">
            <!-- Decorative Quote Icon -->
            <div class="mb-6 opacity-20">
              <svg
                width="32"
                height="24"
                viewBox="0 0 32 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                class="text-primary group-hover:translate-x-1 transition-transform duration-500"
              >
                <path
                  d="M9.14286 0L12 5.33333V24H0V10.6667H6.85714L4 0H9.14286ZM29.1429 0L32 5.33333V24H20V10.6667H26.8571L24 0H29.1429Z"
                  fill="currentColor"></path>
              </svg>
            </div>

            <p
              class="text-2xl md:text-3xl font-display italic font-light leading-tight tracking-tight text-primary/80 group-hover:text-primary transition-colors duration-500 mb-8"
            >
              "La arquitectura es el juego sabio, correcto y magnífico de los
              volúmenes bajo la luz."
            </p>

            <div class="flex items-center gap-4">
              <div
                class="h-px w-8 bg-primary/20 group-hover:w-12 transition-all duration-500"
              >
              </div>
              <span
                class="text-[10px] font-mono opacity-40 uppercase tracking-[0.3em] group-hover:opacity-80 transition-opacity"
              >
                Le Corbusier
              </span>
            </div>
          </div>

          <!-- Floating Grid Detail -->
          <div
            class="absolute -bottom-10 -right-10 w-40 h-40 opacity-[0.05] group-hover:opacity-[0.1] transition-opacity duration-700 pointer-events-none rotate-12"
          >
            <div
              class="w-full h-full"
              style="background-image: radial-gradient(currentColor 1px, transparent 1px); background-size: 16px 16px;"
            >
            </div>
          </div>
        </BentoCard>

        <!-- [03] SIDEBAR RIGHT -->
        <div class="col-span-1 row-span-4 spacing-block"></div>

        <!-- [04] DOME VISUAL -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="primary"
          class="p-0 flex flex-col justify-center items-center overflow-hidden group min-h-[350px] bg-[#1A1A1A]"
        >
          <!-- CSS-only animated wireframe sphere -->
          <div class="absolute inset-0 z-[1] flex items-center justify-center">
            <div class="dome-wireframe w-48 h-48 relative">
              <svg
                viewBox="0 0 200 200"
                class="w-full h-full animate-spin-slow"
              >
                <defs>
                  <linearGradient
                    id="domeGradientEs"
                    x1="0%"
                    y1="0%"
                    x2="100%"
                    y2="100%"
                  >
                    <stop offset="0%" stop-color="#F9E4D4" stop-opacity="0.9"
                    ></stop>
                    <stop offset="100%" stop-color="#E2F0E9" stop-opacity="0.6"
                    ></stop>
                  </linearGradient>
                </defs>
                <!-- Horizontal rings -->
                <ellipse
                  cx="100"
                  cy="100"
                  rx="80"
                  ry="80"
                  fill="none"
                  stroke="url(#domeGradientEs)"
                  stroke-width="0.5"
                  opacity="0.8"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="80"
                  ry="30"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.6"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="80"
                  ry="60"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.5"></ellipse>
                <ellipse
                  cx="100"
                  cy="85"
                  rx="65"
                  ry="25"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.4"></ellipse>
                <ellipse
                  cx="100"
                  cy="115"
                  rx="65"
                  ry="25"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.4"></ellipse>
                <!-- Vertical meridians -->
                <ellipse
                  cx="100"
                  cy="100"
                  rx="30"
                  ry="80"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.5"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="60"
                  ry="80"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.4"></ellipse>
                <ellipse
                  cx="100"
                  cy="100"
                  rx="10"
                  ry="80"
                  fill="none"
                  stroke="#F9E4D4"
                  stroke-width="0.5"
                  opacity="0.3"></ellipse>
                <!-- Diagonal lines for geodesic effect -->
                <line
                  x1="20"
                  y1="100"
                  x2="180"
                  y2="100"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.3"></line>
                <line
                  x1="100"
                  y1="20"
                  x2="100"
                  y2="180"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.3"></line>
                <line
                  x1="35"
                  y1="35"
                  x2="165"
                  y2="165"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.2"></line>
                <line
                  x1="165"
                  y1="35"
                  x2="35"
                  y2="165"
                  stroke="#F9E4D4"
                  stroke-width="0.3"
                  opacity="0.2"></line>
              </svg>
            </div>
          </div>

          <!-- Glassmorphism Overlay Label -->
          <div
            class="absolute bottom-6 left-6 right-6 z-20 p-5 bg-[#F5F4F0]/5 backdrop-blur-md border border-[#F5F4F0]/10 flex justify-between items-end transform translate-y-2 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-700"
          >
            <div>
              <span
                class="text-[8px] font-mono text-[#F5F4F0]/40 uppercase tracking-[0.2em] mb-1 block"
                >Componente</span
              >
              <h4
                class="text-xs font-display font-bold text-[#F5F4F0] uppercase tracking-widest"
              >
                Síntesis Estructural
              </h4>
            </div>
            <div class="text-right">
              <span
                class="text-[8px] font-mono text-[#F5F4F0]/40 uppercase block"
                >Ref. 402-A</span
              >
            </div>
          </div>

          <!-- Top Technical Details -->
          <div
            class="absolute top-6 left-6 right-6 z-20 flex justify-between opacity-30"
          >
            <div class="w-2 h-2 border border-[#F9E4D4]/40"></div>
            <div
              class="text-[7px] font-mono text-[#F9E4D4]/60 uppercase tracking-[0.4em]"
            >
              Simulación Activa
            </div>
            <div class="w-2 h-2 border border-[#F9E4D4]/40"></div>
          </div>
        </BentoCard>

        <!-- [05] PHILOSOPHY -->
        <BentoCard
          id="philosophy"
          colSpan="span 5"
          rowSpan="span 1"
          variant="primary"
          class="p-12 md:p-16 flex flex-col justify-center relative"
        >
          <div
            class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none hatch-pattern"
          >
          </div>
          <span
            class="text-[9px] font-mono opacity-30 uppercase tracking-[0.5em] mb-10 block"
            >Filosofía</span
          >
          <p
            class="text-2xl md:text-3xl font-display italic font-light leading-tight mb-10 max-w-xl"
          >
            "La arquitectura debe hablar de su tiempo y su lugar."
          </p>
          <p
            class="text-[10px] font-mono opacity-40 uppercase tracking-[0.2em]"
          >
            Frank Gehry
          </p>
        </BentoCard>

        <!-- [06] DETAIL IMAGE -->
        <BentoCard
          colSpan="span 2"
          rowSpan="span 1"
          variant="image"
          class="p-0"
        >
          <div class="relative w-full h-full min-h-[300px]">
            <img
              src="/images/projects/concrete-detail.png"
              class="w-full h-full object-cover grayscale brightness-105"
              alt="Detalle"
            />
            <div
              class="absolute bottom-6 left-6 bg-primary text-canvas text-[9px] px-3 py-1.5 font-mono uppercase tracking-widest"
            >
              Detalle 406
            </div>
          </div>
        </BentoCard>

        <!-- [07] OUR PROCESS -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 2"
          variant="surface"
          class="p-10 flex flex-col"
        >
          <span
            class="text-[9px] font-mono opacity-40 uppercase tracking-[0.2em] mb-10 block"
            >Nuestro Proceso</span
          >
          <div class="space-y-6 relative">
            <div
              class="absolute left-[11px] top-2 bottom-2 w-px bg-gridLine/50"
            >
            </div>
            <div class="flex items-start gap-5 relative z-10">
              <div
                class="w-6 h-6 rounded-full border border-primary bg-white flex items-center justify-center text-[10px] font-bold shrink-0"
              >
                1
              </div>
              <p
                class="text-[11px] font-display font-bold uppercase tracking-widest"
              >
                Conceptualizar
              </p>
            </div>
            <div class="flex items-start gap-5 relative z-10 opacity-40">
              <div
                class="w-6 h-6 rounded-full border border-gridLine bg-white flex items-center justify-center text-[10px] font-bold shrink-0"
              >
                2
              </div>
              <p
                class="text-[11px] font-display font-bold uppercase tracking-widest"
              >
                Modelar
              </p>
            </div>
            <div class="flex items-start gap-5 relative z-10 opacity-40">
              <div
                class="w-6 h-6 rounded-full border border-gridLine bg-white flex items-center justify-center text-[10px] font-bold shrink-0"
              >
                3
              </div>
              <p
                class="text-[11px] font-display font-bold uppercase tracking-widest"
              >
                Ejecutar
              </p>
            </div>
          </div>
        </BentoCard>

        <!-- [08] VERTEX TOWER -->
        <BentoCard
          colSpan="span 4"
          rowSpan="span 1"
          variant="surface"
          class="p-0 group"
        >
          <div class="relative w-full h-full flex flex-col min-h-[350px]">
            <div
              class="flex-grow p-8 flex items-center justify-center bg-[#fafafa]"
            >
              <img
                src="/images/projects/vertex.png"
                class="w-3/4 h-auto grayscale opacity-90 mix-blend-multiply group-hover:scale-110 transition-transform duration-1000 ease-out"
                alt="Vertex"
              />
            </div>
            <div
              class="p-8 border-t border-gridLine flex justify-between items-end bg-white"
            >
              <div>
                <h4
                  class="text-xs font-display font-bold uppercase tracking-[0.1em]"
                >
                  Torre Vertex
                </h4>
                <p class="text-[9px] font-mono opacity-40 mt-1">Londres, UK</p>
              </div>
              <Plus
                class="w-3 h-3 opacity-20 group-hover:rotate-90 transition-transform duration-500"
              />
            </div>
          </div>
        </BentoCard>

        <!-- [09] START A PROJECT -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="surface"
          class="flex flex-col items-center justify-center text-center group cursor-pointer hover:bg-[#1A1A1A] transition-all duration-500 p-0 relative min-h-[350px]"
        >
          <div
            class="relative z-10 flex flex-col items-center justify-center p-10 w-full h-full group-hover:text-[#F5F4F0] transition-colors duration-500"
          >
            <div
              class="w-16 h-16 rounded-full bg-[#1A1A1A] text-[#F5F4F0] flex items-center justify-center mb-8 group-hover:bg-[#F5F4F0] group-hover:text-[#1A1A1A] transition-all duration-500 shadow-2xl shadow-black/20 group-hover:shadow-none"
            >
              <Mail class="w-6 h-6" />
            </div>
            <h4
              class="font-display text-lg font-bold uppercase tracking-[0.2em] mb-4"
            >
              Iniciar Proyecto
            </h4>
            <div
              class="w-8 h-px bg-[#1A1A1A]/20 mb-4 group-hover:bg-[#F5F4F0]/30"
            >
            </div>
            <p
              class="text-[10px] font-mono opacity-60 leading-relaxed max-w-[180px] uppercase tracking-widest"
            >
              Actualmente aceptamos nuevos encargos.
            </p>
          </div>
        </BentoCard>
      </BentoGrid>
    </section>

    <!-- Final spacer -->
    <div
      class="w-full h-24 flex items-center justify-center px-12 bg-canvas/30 border-t border-gridLine"
    >
      <div class="w-full h-px bg-gridLine opacity-20"></div>
    </div>

    <Footer lang={lang} />
  </main>
</Layout>

<script>
  import { initAnimations } from "../../utils/animations";
  document.addEventListener("astro:page-load", () => {
    initAnimations();
  });
</script>
