---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import BentoGrid from "../components/BentoGrid.astro";
import BentoCard from "../components/BentoCard.astro";
import Footer from "../components/Footer.astro";
import { useTranslations } from "../utils/i18n";
import { Layers, TrendingUp, ArrowRight, Mail, Plus } from "lucide-astro";

const lang = "en";
const t = useTranslations(lang);
---

<Layout title="Paulina Velazquez | Architect" lang={lang}>
  <Nav lang={lang} />

  <main class="w-full">
    <Hero lang={lang} />

    <section id="work" class="w-full border-t border-gridLine">
      <!-- Section Header aligned to grid -->
      <div class="w-full grid-line-h h-12 flex" style="background-color: var(--spacer-bg);">
        <div class="w-1/12 grid-line-v spacing-block"></div>
        <div class="w-7/12 grid-line-v px-12 md:px-20 flex items-center">
          <h2 class="font-display text-xs font-bold tracking-[0.3em] uppercase opacity-40">
            {t("works.title")}
          </h2>
        </div>
        <div class="w-3/12 grid-line-v spacing-block"></div>
        <div class="w-1/12 spacing-block"></div>
      </div>

      <BentoGrid class="w-full">
        <!-- [00] SIDEBAR LEFT -->
        <BentoCard colSpan="span 1" rowSpan="span 4" class="spacing-block p-0">
          <div class="w-full h-full flex items-center justify-center">
            <span class="text-[10px] font-mono rotate-90 whitespace-nowrap opacity-40 uppercase block">Projects.Archive.24</span>
          </div>
        </BentoCard>

        <!-- [01] MAIN PROJECT: Pantheon Revival (7 cols wide, 2 rows high) -->
        <BentoCard colSpan="span 7" rowSpan="span 2" variant="canvas" class="p-0">
          <div class="group relative w-full h-full min-h-[600px] overflow-hidden">
            <img
              alt="Pantheon Revival"
              class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105 opacity-90 grayscale mix-blend-multiply"
              src="https://images.unsplash.com/photo-1511818966892-d7d671e672a2?w=1200&q=80"
            />
            <div class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none hatch-pattern"></div>
            <div class="absolute top-8 right-8 text-[9px] font-mono opacity-40 uppercase tracking-widest border border-primary/10 px-2 py-1">
              TYPE A1 : r/e: 43
            </div>
            <div class="absolute bottom-12 left-12 right-12 z-20">
              <div class="h-12 w-px bg-primary/30 mb-6"></div>
              <h3 class="font-display text-4xl md:text-5xl font-bold tracking-tight mb-2">Pantheon Revival</h3>
              <p class="text-xs font-mono opacity-60 uppercase tracking-widest">Rome, Italy — 2023</p>
            </div>
          </div>
        </BentoCard>

        <!-- [02] EXPERTISE (3 cols wide) -->
        <BentoCard colSpan="span 3" rowSpan="span 1" variant="surface" class="p-10 flex flex-col justify-between">
          <div class="w-10 h-10 border border-primary/10 rounded-full flex items-center justify-center bg-canvas/30">
            <Layers class="w-4 h-4 opacity-60" />
          </div>
          <div>
            <span class="text-[9px] font-mono opacity-40 uppercase tracking-[0.2em] mb-4 block">Expertise</span>
            <p class="text-2xl font-display font-bold leading-tight tracking-tight">Computational Design & Engineering</p>
          </div>
        </BentoCard>

        <!-- [03] SIDEBAR RIGHT -->
        <BentoCard colSpan="span 1" rowSpan="span 4" class="spacing-block" />

        <!-- [04] STATS (3 cols wide, below Expertise) -->
        <BentoCard colSpan="span 3" rowSpan="span 1" variant="surface" class="p-10 flex flex-col justify-center text-center relative">
          <TrendingUp class="absolute top-6 right-6 w-4 h-4 opacity-10" />
          <div class="space-y-8">
            <div>
              <span class="text-6xl font-display font-bold leading-none tracking-tighter">15+</span>
              <span class="text-[9px] font-mono opacity-40 uppercase block mt-3 tracking-widest">Years Experience</span>
            </div>
            <div class="w-12 h-px bg-gridLine mx-auto"></div>
            <div>
              <span class="text-3xl font-display font-bold leading-none opacity-80">50+</span>
              <span class="text-[9px] font-mono opacity-40 uppercase block mt-1 tracking-widest">Landmarks</span>
            </div>
          </div>
        </BentoCard>

        <!-- [05] PHILOSOPHY (5 cols wide) -->
        <BentoCard id="philosophy" colSpan="span 5" rowSpan="span 1" variant="primary" class="p-12 md:p-16 flex flex-col justify-center relative">
          <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none hatch-pattern"></div>
          <span class="text-[9px] font-mono opacity-30 uppercase tracking-[0.5em] mb-10 block">Philosophy</span>
          <p class="text-2xl md:text-3xl font-display italic font-light leading-tight mb-10 max-w-xl">"Architecture should speak of its time and place."</p>
          <p class="text-[10px] font-mono opacity-40 uppercase tracking-[0.2em]">Frank Gehry</p>
        </BentoCard>

        <!-- [06] DETAIL IMAGE (2 cols wide) -->
        <BentoCard colSpan="span 2" rowSpan="span 1" variant="image" class="p-0">
          <div class="relative w-full h-full min-h-[300px]">
            <img src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=800&q=80" class="w-full h-full object-cover grayscale brightness-105" alt="Detail" />
            <div class="absolute bottom-6 left-6 bg-primary text-canvas text-[9px] px-3 py-1.5 font-mono uppercase tracking-widest">Detail 406</div>
          </div>
        </BentoCard>

        <!-- [07] OUR PROCESS (3 cols wide, 2 rows high) -->
        <BentoCard colSpan="span 3" rowSpan="span 2" variant="surface" class="p-10 flex flex-col">
          <span class="text-[9px] font-mono opacity-40 uppercase tracking-[0.2em] mb-10 block">Our Process</span>
          <div class="space-y-6 relative">
            <div class="absolute left-[11px] top-2 bottom-2 w-px bg-gridLine/50"></div>
            <div class="flex items-start gap-5 relative z-10">
              <div class="w-6 h-6 rounded-full border border-primary bg-white flex items-center justify-center text-[10px] font-bold shrink-0">1</div>
              <p class="text-[11px] font-display font-bold uppercase tracking-widest">Conceptualize</p>
            </div>
            <div class="flex items-start gap-5 relative z-10 opacity-40">
              <div class="w-6 h-6 rounded-full border border-gridLine bg-white flex items-center justify-center text-[10px] font-bold shrink-0">2</div>
              <p class="text-[11px] font-display font-bold uppercase tracking-widest">Model</p>
            </div>
            <div class="flex items-start gap-5 relative z-10 opacity-40">
              <div class="w-6 h-6 rounded-full border border-gridLine bg-white flex items-center justify-center text-[10px] font-bold shrink-0">3</div>
              <p class="text-[11px] font-display font-bold uppercase tracking-widest">Execute</p>
            </div>
          </div>
        </BentoCard>

        <!-- [08] VERTEX TOWER (4 cols wide) -->
        <BentoCard colSpan="span 4" rowSpan="span 1" variant="surface" class="p-0 group">
          <div class="relative w-full h-full flex flex-col min-h-[350px]">
            <div class="flex-grow p-8 flex items-center justify-center bg-[#fafafa]">
              <img src="https://images.unsplash.com/photo-1545558014-8692077e9b5c?w=600&q=80" class="w-3/4 h-auto grayscale opacity-90 mix-blend-multiply group-hover:scale-110 transition-transform duration-1000 ease-out" alt="Vertex" />
            </div>
            <div class="p-8 border-t border-gridLine flex justify-between items-end bg-white">
              <div>
                <h4 class="text-xs font-display font-bold uppercase tracking-[0.1em]">Vertex Tower</h4>
                <p class="text-[9px] font-mono opacity-40 mt-1">London, UK</p>
              </div>
              <Plus class="w-3 h-3 opacity-20 group-hover:rotate-90 transition-transform duration-500" />
            </div>
          </div>
        </BentoCard>

        <!-- [09] START A PROJECT (3 cols wide) -->
        <BentoCard colSpan="span 3" rowSpan="span 1" variant="surface" class="flex flex-col items-center justify-center text-center group cursor-pointer hover:bg-primary transition-all duration-500 p-0 relative min-h-[350px]">
          <div class="relative z-10 flex flex-col items-center justify-center p-10 w-full h-full group-hover:text-canvas transition-colors duration-500">
            <div class="w-16 h-16 rounded-full bg-primary text-canvas flex items-center justify-center mb-8 group-hover:bg-canvas group-hover:text-primary transition-all duration-500 shadow-2xl shadow-primary/20 group-hover:shadow-none">
              <Mail class="w-6 h-6" />
            </div>
            <h4 class="font-display text-lg font-bold uppercase tracking-[0.2em] mb-4">Start a Project</h4>
            <div class="w-8 h-px bg-primary/20 mb-4 group-hover:bg-canvas/30"></div>
            <p class="text-[10px] font-mono opacity-60 leading-relaxed max-w-[180px] uppercase tracking-widest">
              Accepting new commissions.
            </p>
          </div>
        </BentoCard>

      </BentoGrid>
    </section>

    <!-- Final spacer -->
    <div class="w-full h-24 flex items-center justify-center px-12 bg-canvas/30 border-t border-gridLine">
      <div class="w-full h-px bg-gridLine opacity-20"></div>
    </div>

    <Footer lang={lang} />
  </main>
</Layout>

<script>
  import { initAnimations } from "../utils/animations";
  document.addEventListener("astro:page-load", () => {
    initAnimations();
  });
</script>
