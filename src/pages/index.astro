---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import BentoGrid from "../components/BentoGrid.astro";
import BentoCard from "../components/BentoCard.astro";
import Footer from "../components/Footer.astro";
import { useTranslations } from "../utils/i18n";
import {
  Layers,
  TrendingUp,
  ArrowRight,
  Plus,
  Mail,
  Quote,
} from "lucide-astro";

const lang = "en";
const t = useTranslations(lang);
---

<Layout title="Paulina Velazquez | Architect" lang={lang}>
  <Nav lang={lang} />

  <main class="w-full">
    <Hero lang={lang} />

    <section id="work" class="w-full">
      <!-- Section Header -->
      <div class="w-full grid-line-h h-12 flex">
        <div class="w-1/12 grid-line-v spacing-block"></div>
        <div
          class="w-10/12 grid-line-v px-12 md:px-20 flex items-center bg-canvas"
        >
          <h2
            class="font-display text-xs font-bold tracking-[0.3em] uppercase opacity-40"
          >
            {t("works.title")}
          </h2>
        </div>
        <div class="w-1/12 spacing-block"></div>
      </div>

      <BentoGrid class="w-full">
        <!-- Sidebar Spacing -->
        <BentoCard
          colSpan="span 1"
          rowSpan="span 3"
          class="spacing-block flex items-center justify-center min-h-[600px]"
        >
          <span
            class="text-[10px] font-mono rotate-90 whitespace-nowrap opacity-40"
            >SYSTEM.BENTO.04</span
          >
        </BentoCard>

        <!-- [01] MAIN PROJECT (Canvas) -->
        <BentoCard
          colSpan="span 7"
          rowSpan="span 2"
          variant="canvas"
          class="p-0"
        >
          <div
            class="group relative w-full h-[600px] md:h-full overflow-hidden"
          >
            <img
              alt="Detailed architectural drawing of a dome section"
              class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105 opacity-90 grayscale mix-blend-multiply"
              src="https://images.unsplash.com/photo-1511818966892-d7d671e672a2?w=1200&q=80"
            />
            <div
              class="absolute inset-0 bg-primary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none hatch-pattern"
            >
            </div>

            <div
              class="absolute bottom-12 left-12 right-12 flex justify-between items-end z-20"
            >
              <div class="max-w-md">
                <span
                  class="text-[10px] font-mono text-primary/60 tracking-widest uppercase mb-4 block"
                >
                  {t("works.pantheon.location")}
                </span>
                <h3
                  class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-none mb-2"
                >
                  {t("works.pantheon.title")}
                </h3>
              </div>
              <div
                class="bg-primary text-white p-4 group-hover:bg-primary/90 transition-colors"
              >
                <ArrowRight class="w-6 h-6" />
              </div>
            </div>
          </div>
        </BentoCard>

        <!-- [02] CORE METRICS (Primary - Black) -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="primary"
          class="p-10 flex flex-col justify-between"
        >
          <div class="flex justify-between items-start">
            <span
              class="text-[10px] font-mono opacity-50 uppercase tracking-widest"
              >METRICS.V4</span
            >
            <TrendingUp class="w-4 h-4 opacity-40" />
          </div>
          <div class="space-y-8">
            <div class="flex items-end gap-3">
              <span
                class="text-6xl font-display font-bold leading-none tracking-tighter"
                >15</span
              >
              <span class="text-[10px] font-mono opacity-40 uppercase mb-1"
                >{t("stats.years")}</span
              >
            </div>
            <div class="flex items-end gap-3">
              <span
                class="text-6xl font-display font-bold leading-none tracking-tighter"
                >50+</span
              >
              <span class="text-[10px] font-mono opacity-40 uppercase mb-1"
                >{t("stats.landmarks")}</span
              >
            </div>
          </div>
          <div class="pt-6 border-t border-canvas/10">
            <p class="text-[9px] font-mono opacity-30 leading-tight uppercase">
              High Precision Architectural Delivery
            </p>
          </div>
        </BentoCard>

        <!-- [03] TECH STACK (Primary - Black) -->
        <BentoCard
          colSpan="span 3"
          rowSpan="span 1"
          variant="primary"
          class="p-10 flex flex-col justify-between"
        >
          <div>
            <span
              class="text-[10px] font-mono opacity-50 uppercase tracking-widest mb-10 block"
              >EXPERTISE.CORE</span
            >
            <div class="space-y-4">
              <div
                class="flex justify-between items-center text-[10px] font-mono opacity-60"
              >
                <span>V-RAY / RHINO</span>
                <Plus class="w-3 h-3" />
              </div>
              <div
                class="flex justify-between items-center text-[10px] font-mono opacity-60"
              >
                <span>PARAMETRIC DESIGN</span>
                <Plus class="w-3 h-3" />
              </div>
              <div
                class="flex justify-between items-center text-[10px] font-mono opacity-60"
              >
                <span>URBAN PLANNING</span>
                <Plus class="w-3 h-3" />
              </div>
            </div>
          </div>
          <div
            class="w-10 h-10 border border-canvas/20 flex items-center justify-center"
          >
            <Layers class="w-4 h-4 opacity-50" />
          </div>
        </BentoCard>

        <!-- [04] PHILOSOPHY (Primary - Full span) -->
        <BentoCard
          id="philosophy"
          colSpan="span 10"
          rowSpan="span 1"
          variant="primary"
          class="p-16 md:p-32 flex items-center justify-center text-center"
        >
          <div class="max-w-4xl">
            <span
              class="block text-canvas/30 text-[10px] font-mono tracking-[0.5em] uppercase mb-12"
            >
              CORE PHILOSOPHY
            </span>
            <p
              class="text-3xl md:text-6xl font-display italic font-light leading-tight mb-12"
            >
              "{t("philosophy.quote")}"
            </p>
            <span
              class="block text-canvas/50 text-xs font-mono uppercase tracking-[0.2em]"
            >
              — {t("philosophy.author")}
            </span>
          </div>
        </BentoCard>

        <!-- Sidebar Spacing -->
        <BentoCard colSpan="span 1" rowSpan="span 3" class="spacing-block" />
      </BentoGrid>

      <!-- Second Module Grid -->
      <BentoGrid class="w-full">
        <BentoCard colSpan="span 1" class="spacing-block min-h-[450px]" />

        <!-- [05] SECONDARY PROJECT (Canvas) -->
        <BentoCard colSpan="span 7" variant="canvas" class="p-0">
          <div
            class="group relative w-full h-[450px] md:h-full overflow-hidden"
          >
            <img
              alt="Vertex Tower Project"
              class="w-full h-full object-cover grayscale mix-blend-multiply opacity-80"
              src="https://images.unsplash.com/photo-1545558014-8692077e9b5c?w=1200&q=80"
            />
            <div class="absolute inset-0 p-12 flex flex-col justify-between">
              <div class="flex justify-between">
                <span
                  class="bg-primary text-canvas text-[9px] px-2 py-1 uppercase font-mono tracking-widest"
                  >EST. 2024</span
                >
                <span
                  class="text-[10px] font-mono text-primary/40 uppercase tracking-widest"
                  >PROJ: {t("vertex.location")}</span
                >
              </div>
              <div class="flex justify-between items-end">
                <div>
                  <h3
                    class="font-display text-5xl font-bold tracking-tight leading-none mb-2"
                  >
                    {t("vertex.title")}
                  </h3>
                  <p class="text-[10px] font-mono uppercase opacity-40">
                    {t("works.pantheon.type")}
                  </p>
                </div>
                <div
                  class="w-16 h-16 border border-primary flex items-center justify-center group-hover:bg-primary group-hover:text-canvas transition-all duration-500"
                >
                  <ArrowRight class="w-6 h-6" />
                </div>
              </div>
            </div>
          </div>
        </BentoCard>

        <!-- [06] TECHNICAL SPECS (Primary) -->
        <BentoCard
          colSpan="span 3"
          variant="primary"
          class="p-10 flex flex-col justify-between"
        >
          <div>
            <span
              class="text-[10px] font-mono opacity-50 uppercase tracking-widest mb-10 block"
              >TECHNICAL.SPEC</span
            >
            <p
              class="text-sm font-display font-medium leading-relaxed uppercase opacity-80 mb-6"
            >
              Integration of parametric logic into high-density residential
              structures for optimized thermal performance.
            </p>
          </div>
          <div class="space-y-2">
            <div
              class="p-4 border border-canvas/10 font-mono text-[9px] opacity-40"
            >
              REF_CODE: 2024.VTX.AX
            </div>
            <div
              class="p-4 border border-canvas/10 font-mono text-[9px] opacity-40"
            >
              STATUS: CONSTRUCTION
            </div>
          </div>
        </BentoCard>

        <BentoCard colSpan="span 1" class="spacing-block" />
      </BentoGrid>
    </section>

    <!-- CONTACT CTA -->
    <section id="contact" class="w-full grid-line-h">
      <div class="flex w-full min-h-[60vh]">
        <div class="w-1/12 grid-line-v spacing-block"></div>
        <div
          class="w-10/12 grid-line-v p-16 md:p-48 flex flex-col items-center justify-center bg-canvas text-center"
        >
          <div class="w-20 h-px bg-primary/20 mb-12"></div>
          <h2
            class="font-display text-5xl md:text-9xl font-bold tracking-tighter mb-16 leading-[0.85]"
          >
            LET'S BUILD <br />
            <span class="italic font-light">BEYOND.</span>
          </h2>
          <a
            href="mailto:hello@paulinavlzqz.com"
            class="group flex items-center gap-10 text-2xl md:text-4xl font-display font-bold hover:opacity-70 transition-opacity"
          >
            hello@paulinavlzqz.com
            <div
              class="w-24 h-24 border border-primary flex items-center justify-center group-hover:translate-x-4 transition-transform duration-700"
            >
              <ArrowRight class="w-10 h-10" />
            </div>
          </a>
          <div
            class="mt-20 text-[10px] font-mono opacity-30 uppercase tracking-[0.3em]"
          >
            {t("contact.description")}
          </div>
        </div>
        <div class="w-1/12 spacing-block"></div>
      </div>
    </section>

    <Footer lang={lang} />
  </main>
</Layout>

  <script>
    import { initAnimations } from "../utils/animations";
    
    // Only use the event listener to avoid double execution on first load
    document.addEventListener("astro:page-load", () => {
      initAnimations();
    });
  </script>
