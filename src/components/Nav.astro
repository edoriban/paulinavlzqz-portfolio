---
import { useTranslations, type Language } from "../utils/i18n";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const otherLang = lang === "en" ? "es" : "en";
const otherLangUrl = lang === "en" ? "/es/" : "/";
---

<nav
  class="w-full grid-line-h sticky top-0 z-50 px-0"
  style="background-color: #EFEEE9 !important; opacity: 1 !important;"
>
  <div class="flex w-full">
    <!-- Technical Block -->
    <div
      class="hidden md:flex w-1/12 grid-line-v h-20 items-center justify-center bg-[#EFEEE9] spacing-block-solid"
    >
      <span class="text-[10px] font-mono rotate-90 whitespace-nowrap"
        >NAV.01</span
      >
    </div>

    <!-- Main Navigation Content -->
    <div class="flex-1 grid-line-v flex items-center">
      <a
        href={lang === "en" ? "/" : "/es/"}
        class="px-4 md:px-12 font-display font-bold text-base md:text-xl tracking-tight uppercase whitespace-nowrap"
      >
        Paulina Velazquez
      </a>

      <!-- Hatched Separator -->
      <div class="flex-1 h-full hatch-pattern-solid border-l border-gridLine">
      </div>

      <div
        class="hidden md:flex items-center gap-8 lg:gap-12 font-medium text-sm px-12 border-l border-gridLine self-stretch"
      >
        <a
          class="hover:opacity-60 transition-opacity uppercase tracking-widest text-xs"
          href="#work">{t("nav.work")}</a
        >
        <a
          class="hover:opacity-60 transition-opacity uppercase tracking-widest text-xs"
          href="#philosophy">{t("nav.philosophy")}</a
        >

        <div class="flex gap-2 text-primary/40 font-mono text-xs">
          {
            lang === "en" ? (
              <>
                <span class="text-primary font-bold">EN</span>
                <span>/</span>
                <a
                  href={otherLangUrl}
                  class="hover:text-primary transition-colors"
                  data-astro-reload
                >
                  ES
                </a>
              </>
            ) : (
              <>
                <a
                  href={otherLangUrl}
                  class="hover:text-primary transition-colors"
                  data-astro-reload
                >
                  EN
                </a>
                <span>/</span>
                <span class="text-primary font-bold">ES</span>
              </>
            )
          }
        </div>
      </div>
    </div>

    <!-- Contact Button Block -->
    <div
      class="w-3/12 md:w-2/12 h-20 flex items-center justify-center px-4 md:px-8"
    >
      <a
        href="#contact"
        class="w-full bg-primary text-white border border-primary px-4 md:px-6 py-2 hover:opacity-90 transition-all text-sm font-bold text-center uppercase tracking-widest"
      >
        {t("nav.contact")}
      </a>
    </div>
  </div>
</nav>

<style>
  /* Ensure the grid line colors match the design tokens */
  .grid-line-h {
    border-bottom: 1px solid var(--grid-line);
  }
  .grid-line-v {
    border-right: 1px solid var(--grid-line);
  }

  .spacing-block-solid {
    background-color: #efeee9;
    background-image: radial-gradient(
      var(--grid-line) 0.5px,
      transparent 0.5px
    );
    background-size: 10px 10px;
  }

  .hatch-pattern-solid {
    background-color: #efeee9;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 4px,
      var(--grid-line) 5px,
      var(--grid-line) 5.5px
    );
  }
</style>
