---
import { Image } from "astro:assets";
import { useTranslations, type Language } from "../utils/i18n";
import sagrarioHero from "../assets/images/sagrario-hero.png";

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<header class="w-full grid-line-h">
    <!-- Horizontal Separation Spacer with vertical grid lines -->
    <div class="w-full grid-line-h h-12 hidden md:flex">
        <div class="w-1/12 grid-line-v spacing-block"></div>
        <div class="w-7/12 grid-line-v spacing-block"></div>
        <div class="w-3/12 grid-line-v spacing-block"></div>
        <div class="w-1/12 spacing-block"></div>
    </div>

    <div class="flex flex-col md:flex-row w-full">
        <!-- Left Spacing Block (1/12) -->
        <div
            class="hidden md:flex w-1/12 grid-line-v items-center justify-center spacing-block relative min-h-[500px]"
        >
            <span
                class="text-[10px] font-mono rotate-90 whitespace-nowrap opacity-40"
                >HERO.SECTION.01</span
            >
        </div>

        <!-- Hero Content (7/12) -->
        <div
            class="w-full md:w-7/12 grid-line-v p-8 py-16 md:p-20 flex flex-col justify-center bg-canvas"
        >
            <div class="flex items-center gap-3 mb-10">
                <div
                    class="bg-primary text-white text-[9px] px-2 py-1 tracking-widest uppercase font-mono"
                >
                    NEW
                </div>
                <div
                    class="text-[10px] text-primary tracking-widest uppercase font-mono opacity-60"
                >
                    {t("hero.label")}
                </div>
            </div>

            <h1
                class:list={[
                    "font-display font-bold leading-[0.9] tracking-tighter mb-10 text-primary text-balance",
                    lang === "es" 
                        ? "text-4xl md:text-6xl lg:text-6xl xl:text-7xl" 
                        : "text-5xl md:text-7xl lg:text-7xl xl:text-8xl"
                ]}
            >
                {t("hero.title.part1")}
                {t("hero.title.part2")}
                <span class="italic font-light"
                    >{t("hero.title.part2.italic")}</span
                >
            </h1>

            <p
                class="text-lg md:text-xl max-w-lg text-primary/70 font-light leading-snug mb-12"
            >
                {t("hero.description")}
            </p>

            <div class="flex flex-wrap gap-4">
                <button
                    class="bg-primary text-white px-10 py-5 hover:opacity-90 transition-opacity flex items-center gap-4 font-bold text-[11px] uppercase tracking-[0.2em]"
                >
                    {t("hero.cta.view")}
                    <span class="material-symbols-outlined text-lg"
                        >arrow_forward</span
                    >
                </button>
            </div>
        </div>

        <!-- Hero Image Area (3/12) -->
        <div
            class="hidden md:flex w-3/12 grid-line-v relative bg-canvas items-center justify-center overflow-hidden"
        >
            <!-- Grid Overlay Effect -->
            <div class="absolute inset-0 opacity-[0.07] pointer-events-none">
                <svg
                    width="100%"
                    height="100%"
                    viewBox="0 0 100 100"
                    preserveAspectRatio="none"
                >
                    <defs>
                        <pattern
                            id="hero-grid"
                            width="10"
                            height="10"
                            patternUnits="userSpaceOnUse"
                        >
                            <path
                                d="M 10 0 L 0 0 0 10"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="0.2"></path>
                        </pattern>
                    </defs>
                    <rect width="100" height="100" fill="url(#hero-grid)"
                    ></rect>
                </svg>
            </div>

            <Image
                src={sagrarioHero}
                alt="Technical architectural drawing of Sagrario Metropolitano dome structure"
                class="relative z-10 w-[90%] h-auto grayscale mix-blend-multiply opacity-90"
                widths={[320, 640]}
                sizes="25vw"
            />

            <!-- Technical Decorative Block -->
            <div
                class="absolute bottom-10 right-10 border border-gridLine p-5 bg-canvas/40 backdrop-blur-md hidden lg:block"
            >
                <div class="font-mono text-[9px] space-y-1.5 opacity-80">
                    <div class="flex justify-between gap-10">
                        <span>STRUCT:</span>
                        <span>DOME-V1</span>
                    </div>
                    <div class="flex justify-between gap-10">
                        <span>VAR:</span>
                        <span>STABLE</span>
                    </div>
                    <div class="flex justify-between gap-10">
                        <span>COORD:</span>
                        <span>42° N 12° E</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Spacing Block (1/12) -->
        <div class="hidden md:block w-1/12 h-full spacing-block min-h-[500px]"></div>
    </div>
</header>

<style>
    .grid-line-h {
        border-bottom: 1px solid var(--grid-line);
    }
    .grid-line-v {
        border-right: 1px solid var(--grid-line);
    }
</style>
