---
import { useTranslations, type Language } from "../utils/i18n";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="w-full">
    <!-- Horizontal Separation Spacer with vertical grid lines -->
    <div class="w-full grid-line-h h-12 hidden md:flex">
        <div class="w-1/12 grid-line-v spacing-block"></div>
        <div class="w-10/12 grid-line-v spacing-block"></div>
        <div class="w-1/12 spacing-block"></div>
    </div>

    <!-- Footer Main Row -->
    <div class="flex w-full grid-line-h">
        <!-- Left Spacing Block (1/12) -->
        <div
            class="hidden md:flex w-1/12 grid-line-v items-center justify-center spacing-block"
        >
            <span
                class="text-[10px] font-mono rotate-90 whitespace-nowrap opacity-40"
                >FOOTER.01</span
            >
        </div>

        <!-- Footer Content (10/12) -->
        <div
            class="w-full md:w-10/12 grid-line-v px-6 md:px-20 py-12 md:py-20 bg-canvas"
        >
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 items-start">
                <!-- Brand -->
                <div class="col-span-1 md:col-span-3">
                    <span class="font-display font-bold text-xl tracking-tight uppercase block mb-6"
                        >Paulina Velazquez</span
                    >
                    <p
                        class="text-[10px] text-primary/60 font-mono tracking-widest uppercase leading-loose"
                    >
                        {t("footer.tagline")}
                    </p>
                </div>

                <!-- Legal -->
                <div class="col-span-1">
                    <h5
                        class="font-display text-[11px] font-bold text-primary mb-6 uppercase tracking-widest"
                    >
                        {t("footer.legal")}
                    </h5>
                    <ul
                        class="space-y-3 text-[11px] text-primary/60 font-mono tracking-wider"
                    >
                        <li>
                            <a class="hover:text-primary transition-colors uppercase" href={lang === "es" ? "/es/privacidad" : "/privacy"}>{t("footer.privacy")}</a>
                        </li>
                        <li>
                            <a class="hover:text-primary transition-colors uppercase" href={lang === "es" ? "/es/terminos" : "/terms"}>{t("footer.terms")}</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Right Spacing Block (1/12) -->
        <div class="hidden md:block w-1/12 spacing-block"></div>
    </div>

    <!-- Bottom Copyright Bar -->
    <div class="flex w-full">
        <div class="hidden md:block w-1/12 grid-line-v spacing-block h-12"></div>
        <div class="w-full md:w-10/12 grid-line-v h-12 flex items-center px-6 md:px-20">
            <span class="text-[9px] text-primary/40 font-mono tracking-widest uppercase"
                >&copy; {new Date().getFullYear()} Paulina Velazquez</span
            >
        </div>
        <div class="hidden md:block w-1/12 spacing-block h-12"></div>
    </div>
</footer>

<style>
    .grid-line-h {
        border-bottom: 1px solid var(--grid-line);
    }
    .grid-line-v {
        border-right: 1px solid var(--grid-line);
    }
</style>
