---
import { useTranslations, type Language } from "../utils/i18n";

interface Props {
    lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="w-full bg-[#1A1A1A] relative overflow-hidden">
    <!-- Architectural floor plan as full background -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <svg
            viewBox="0 0 200 200"
            class="w-[min(80%,700px)] h-auto opacity-[0.06]"
            fill="none"
            stroke="#F9E4D4"
            stroke-width="0.5"
        >
            <rect x="20" y="20" width="160" height="160" stroke-width="1"></rect>
            <rect x="20" y="20" width="80" height="90"></rect>
            <rect x="100" y="20" width="80" height="60"></rect>
            <rect x="100" y="80" width="80" height="30"></rect>
            <rect x="20" y="110" width="50" height="70"></rect>
            <rect x="70" y="110" width="60" height="70"></rect>
            <rect x="130" y="110" width="50" height="70"></rect>
            <path d="M 60 110 A 10 10 0 0 1 70 100"></path>
            <path d="M 100 50 A 10 10 0 0 0 110 60"></path>
            <path d="M 90 180 A 10 10 0 0 1 100 170"></path>
            <line x1="20" y1="12" x2="180" y2="12" stroke-dasharray="2,4"></line>
            <line x1="12" y1="20" x2="12" y2="180" stroke-dasharray="2,4"></line>
            <line x1="20" y1="10" x2="20" y2="14"></line>
            <line x1="100" y1="10" x2="100" y2="14"></line>
            <line x1="180" y1="10" x2="180" y2="14"></line>
            <line x1="95" y1="100" x2="105" y2="100"></line>
            <line x1="100" y1="95" x2="100" y2="105"></line>
            <circle cx="100" cy="100" r="3"></circle>
        </svg>
    </div>

    <div class="flex w-full">
        <!-- Left Spacing Block (1/12) -->
        <div
            class="hidden md:flex w-1/12 border-r border-white/[0.07] items-center justify-center spacing-block"
        >
            <span
                class="text-[10px] font-mono rotate-90 whitespace-nowrap text-[#F9E4D4]/20"
                >CTA.05</span
            >
        </div>

        <!-- CTA Content (10/12) -->
        <div
            class="w-full md:w-10/12 border-r border-white/[0.07] py-16 md:py-32 px-6 md:px-20 relative z-10"
        >
            <!-- Top meta row -->
            <div class="flex items-center justify-between mb-12 md:mb-20">
                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 bg-[#E2F0E9] rounded-full animate-pulse"></div>
                    <span class="text-[10px] font-mono text-[#F9E4D4]/40 uppercase tracking-[0.3em]"
                        >{t("cta.label")}</span
                    >
                </div>
                <span class="text-[9px] font-mono text-[#F9E4D4]/20 uppercase tracking-widest hidden md:block"
                    >{t("cta.coord")}</span
                >
            </div>

            <!-- Centered content -->
            <div class="max-w-3xl mx-auto text-center">
                <h2
                    class="font-display font-bold text-4xl md:text-6xl lg:text-7xl leading-[0.95] tracking-tighter mb-8 text-[#F5F4F0]"
                >
                    {t("cta.title.line1")} {t("cta.title.line2")}<br />
                    <span class="italic font-light text-[#F9E4D4]/70">{t("cta.title.line3")}</span>
                </h2>

                <p
                    class="text-base md:text-lg max-w-md mx-auto text-[#F5F4F0]/40 font-light leading-relaxed mb-14"
                >
                    {t("cta.description")}
                </p>

                <!-- Email button -->
                <a
                    href="mailto:paulina@velazquez.com"
                    class="group/btn inline-flex items-center gap-3 md:gap-4 border border-[#F9E4D4]/20 hover:border-[#F9E4D4]/50 hover:bg-[#F9E4D4]/5 px-6 md:px-10 py-4 md:py-5 transition-all duration-500"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-5 h-5 text-[#F9E4D4]/60 group-hover/btn:text-[#F9E4D4] transition-colors"
                    >
                        <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                    </svg>
                    <span class="text-[#F5F4F0]/80 group-hover/btn:text-[#F5F4F0] font-bold text-[11px] uppercase tracking-[0.2em] transition-colors"
                        >{t("cta.button")}</span
                    >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="w-4 h-4 text-[#F9E4D4]/40 group-hover/btn:text-[#F9E4D4] group-hover/btn:translate-x-1 transition-all"
                    >
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </a>
            </div>

            <!-- Bottom meta row -->
            <div class="flex items-center justify-between mt-12 md:mt-20">
                <div class="flex items-center gap-6">
                    <div class="h-px w-12 bg-[#F9E4D4]/10"></div>
                    <span class="text-[9px] font-mono text-[#F9E4D4]/20 uppercase tracking-widest"
                        >REF: CTA-001</span
                    >
                </div>
                <div class="flex items-center gap-6">
                    <span class="text-[9px] font-mono text-[#F9E4D4]/20 uppercase tracking-widest hidden md:block"
                        >STATUS: AVAILABLE</span
                    >
                    <div class="h-px w-12 bg-[#F9E4D4]/10"></div>
                </div>
            </div>
        </div>

        <!-- Right Spacing Block (1/12) -->
        <div class="hidden md:block w-1/12 spacing-block"></div>
    </div>
</section>
